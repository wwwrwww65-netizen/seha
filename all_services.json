      "<div class=\"service-card\"><img alt=\"service-icon\" src=\"data:image/svg+xml,%3csvg%20xmlns='http://www.w3.org/2000/svg'%20width='55'%20height='55'%20viewBox='0%200%2055%2055'%3e%3cg%20id='Group_4973'%20data-name='Group%204973'%20transform='translate(-1139.5%20-844.919)'%3e%3cg%20id='Group_114'%20data-name='Group%20114'%20transform='translate(1139.5%20844.919)'%3e%3crect%20id='Rectangle_25'%20data-name='Rectangle%2025'%20width='55'%20height='55'%20rx='15'%20fill='%23f4f7fb'/%3e%3c/g%3e%3cg%20id='medicine'%20transform='translate(1138.799%20855.919)'%3e%3cg%20id='Group_4975'%20data-name='Group%204975'%20transform='translate(22.148%208.123)'%3e%3cg%20id='Group_4974'%20data-name='Group%204974'%3e%3cpath%20id='Path_9047'%20data-name='Path%209047'%20d='M116.341,125.994a.645.645,0,1,0,.645.645A.645.645,0,0,0,116.341,125.994Z'%20transform='translate(-115.696%20-125.994)'%20fill='%237eb7db'/%3e%3c/g%3e%3c/g%3e%3cg%20id='Group_4977'%20data-name='Group%204977'%20transform='translate(22.793%2017.6)'%3e%3cg%20id='Group_4976'%20data-name='Group%204976'%3e%3cpath%20id='Path_9048'%20data-name='Path%209048'%20d='M131.5,275.565h-1.934v-1.934a.645.645,0,1,0-1.289,0v1.934h-1.934a.645.645,0,1,0,0,1.289h1.934v1.934a.645.645,0,1,0,1.289,0v-1.934H131.5a.645.645,0,1,0,0-1.289Z'%20transform='translate(-125.696%20-272.986)'%20fill='%237eb7db'/%3e%3c/g%3e%3c/g%3e%3cg%20id='Group_4979'%20data-name='Group%204979'%20transform='translate(15.701)'%3e%3cg%20id='Group_4978'%20data-name='Group%204978'%3e%3cpath%20id='Path_9049'%20data-name='Path%209049'%20d='M46,20.759a5.155,5.155,0,0,0-7.045-1.888l-2.619,1.512v-5.6a3.247,3.247,0,0,0-.645-1.934l-3.223-4.3V6.723A1.937,1.937,0,0,0,33.753,4.9V1.934A1.936,1.936,0,0,0,31.818,0h-11.6A1.936,1.936,0,0,0,18.28,1.934V4.9a1.937,1.937,0,0,0,1.289,1.823v1.83l-3.224,4.3a3.246,3.246,0,0,0-.644,1.934V27.271a3.227,3.227,0,0,0,3.223,3.223H29.285a5.152,5.152,0,0,0,7.006,1.823L44.108,27.8A5.161,5.161,0,0,0,46,20.759ZM19.569,1.934a.645.645,0,0,1,.645-.645h11.6a.6